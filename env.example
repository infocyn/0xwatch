# 0xWatch — Environment Configuration
# cp env.example .env  &&  chmod 600 .env

# ── Discord ──────────────────────────────────────────────
# Create webhook: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK=

# ── Telegram ─────────────────────────────────────────────
# Create bot via @BotFather · find chat ID via @getidsbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Proxy ────────────────────────────────────────────────
# SOCKS5 proxy for all clearnet requests (optional)
# Format: socks5h://user:pass@host:port
CLEARNET_PROXY=
